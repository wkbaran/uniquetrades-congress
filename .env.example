# Required for SEC EDGAR API access (public domain, no cost).
# Format: "Your Name your@email.com"
SEC_USER_AGENT=Your Name your@email.com

# Set to "fmp" to use Financial Modeling Prep instead of SEC EDGAR + StockWatcher.
# Used during parallel validation phase. Default: open (public-domain sources).
# DATA_SOURCE=fmp

# Only needed when DATA_SOURCE=fmp
# FMP_API_KEY=your_fmp_api_key_here

# AWS S3 publishing
# S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1
# CLOUDFRONT_DISTRIBUTION_ID=your-distribution-id
